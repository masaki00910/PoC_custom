# =============================================================================
# Project-wide .gitignore
# 各サブリポジトリ (backend/, frontend/, database/) は独自の .gitignore も持つ
# =============================================================================

# -----------------------------------------------------------------------------
# 個人情報・内部データ (絶対コミットしない)
# backend/CLAUDE.md §6 のハードルールに準拠
# -----------------------------------------------------------------------------
sample_data/
**/sample_data/

# 個別の本番由来データ
*-uat.csv
*-prod.csv
*_real.csv

# -----------------------------------------------------------------------------
# Claude Code ローカル設定 (個人環境用)
# -----------------------------------------------------------------------------
.claude/settings.local.json
.claude/local/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/
uv.lock

# -----------------------------------------------------------------------------
# Node / TypeScript / Frontend
# -----------------------------------------------------------------------------
node_modules/
*.tsbuildinfo
.npm/
.yarn/
.pnpm-store/

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
*.zip
!docs/**/*.zip
out/
build/
dist/

# -----------------------------------------------------------------------------
# 環境変数 / Secret
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# IDE / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs / temp
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/

# -----------------------------------------------------------------------------
# 大容量マスタデータ (任意 - スリム化したい場合は uncomment)
# -----------------------------------------------------------------------------
# database/masters/utf_ken_all.csv      # 18MB の日本郵便公開データ。download スクリプトで取得する運用に変えるなら有効化
