# 環境名 (local / dev / stg / prd)
APP_ENV=local

# AI クライアント切替 (fake / bedrock_proxy)
AI_CLIENT=fake

# Bedrock プロキシ (AI_CLIENT=bedrock_proxy 時のみ参照、次タスクで実装)
BEDROCK_PROXY_URL=https://6mlsx5sseg.execute-api.ap-northeast-1.amazonaws.com/dev/chat
BEDROCK_PROXY_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_PROXY_TIMEOUT_SECONDS=30

# ログレベル
LOG_LEVEL=INFO
