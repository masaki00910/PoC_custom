# 環境名 (local / dev / stg / prd)
APP_ENV=local

# ログレベル
LOG_LEVEL=INFO

# ============================================================================
# AI プロバイダ設定
# ============================================================================
# ネスト区切りは "__" (config.py の env_nested_delimiter)。
# 例: AI__BEDROCK_PROXY__URL → Settings.ai.bedrock_proxy.url

# AI クライアント切替 (fake / bedrock_proxy / 将来: vertex_ai / azure_openai 等)
AI__PROVIDER=fake

# Bedrock プロキシ (AI__PROVIDER=bedrock_proxy 時のみ参照、T-002 で実装)
AI__BEDROCK_PROXY__URL=https://6mlsx5sseg.execute-api.ap-northeast-1.amazonaws.com/dev/chat
AI__BEDROCK_PROXY__MODEL=global.anthropic.claude-sonnet-4-6
AI__BEDROCK_PROXY__TIMEOUT_SECONDS=30
